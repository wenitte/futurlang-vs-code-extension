{
  "name": "futurlang",
  "displayName": "FuturLang",
  "description": "Syntax highlighting, diagnostics, hover docs and completions for FuturLang (.fl)",
  "version": "0.2.0",
  "publisher": "WenitteApiou",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:futurlang"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/futurlang/futurlang"
  },
  "contributes": {
    "languages": [
      {
        "id": "futurlang",
        "aliases": [
          "FuturLang",
          "fl"
        ],
        "extensions": [
          ".fl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "futurlang",
        "scopeName": "source.fl",
        "path": "./syntaxes/futurlang.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build:server": "cd ../futurlang && npx esbuild src/lsp-stdio.ts --bundle --platform=node --target=node18 --external:vscode --outfile=../futurlang-vs-code-extension/server/lsp-stdio.js",
    "build:ext": "npx esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=out/extension.js",
    "build": "npm run build:server && npm run build:ext",
    "package": "npm run build && vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
