{
  "name": "futurlang",
  "displayName": "FuturLang",
  "description": "Syntax highlighting for FuturLang (.fl) — a formal proof and blockchain programming language",
  "version": "0.1.0",
  "publisher": "WenitteApiou",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "repository": {
    "type": "git",
    "url": "https://github.com/futurlang/futurlang"
  },
  "contributes": {
    "languages": [
      {
        "id": "futurlang",
        "aliases": ["FuturLang", "fl"],
        "extensions": [".fl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "futurlang",
        "scopeName": "source.fl",
        "path": "./syntaxes/futurlang.tmLanguage.json"
      }
    ],
    "themes": []
  },
  "devDependencies": {
    "@vscode/vsce": "^2.24.0"
  }
}
